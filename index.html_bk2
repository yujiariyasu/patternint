<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8">
  <title>Pattern Intelligence</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Pattern Intelligence is an AI engineering studio focused on computer vision, medical imaging AI, and practical machine learning systems.">
  <link href="./style.css" rel="stylesheet">
  <script>
    if (localStorage.getItem('dark-mode') === 'false' || !('dark-mode' in localStorage)) {
      document.querySelector('html').classList.remove('dark');
    } else {
      document.querySelector('html').classList.add('dark');
    }
  </script>
</head>
<body class="font-inter antialiased bg-gray-50 text-gray-800 dark:bg-gray-950 dark:text-gray-100 tracking-tight">
  <div class="overflow-hidden supports-[overflow:clip]:overflow-clip">
    <div class="max-w-[728px] mx-auto">
      <div class="w-full bg-white dark:bg-gray-900 border-x border-gray-100 dark:border-gray-800 box-content">
        <div class="px-3 md:px-16">
          <div class="flex flex-col min-h-screen">

            <header class="pt-6">
              <div class="flex justify-end mb-8">
                <div class="inline-flex items-center justify-center ml-auto">
                  <input type="checkbox" name="light-switch" id="light-switch" class="light-switch sr-only" />
                  <label class="relative cursor-pointer p-2" for="light-switch">
                    <svg class="dark:hidden" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                      <path class="fill-gray-300" d="M7 0h2v2H7zM12.88 1.637l1.414 1.415-1.415 1.413-1.413-1.414zM14 7h2v2h-2zM12.95 14.433l-1.414-1.413 1.413-1.415 1.415 1.414zM7 14h2v2H7zM2.98 14.364l-1.413-1.415 1.414-1.414 1.414 1.415zM0 7h2v2H0zM3.05 1.706 4.463 3.12 3.05 4.535 1.636 3.12z" />
                      <path class="fill-gray-400" d="M8 4C5.8 4 4 5.8 4 8s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4Z" />
                    </svg>
                    <svg class="hidden dark:block" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                      <path class="fill-gray-500" d="M6.2 1C3.2 1.8 1 4.6 1 7.9 1 11.8 4.2 15 8.1 15c3.3 0 6-2.2 6.9-5.2C9.7 11.2 4.8 6.3 6.2 1Z" />
                      <path class="fill-gray-400" d="M12.5 5a.625.625 0 0 1-.625-.625 1.252 1.252 0 0 0-1.25-1.25.625.625 0 1 1 0-1.25 1.252 1.252 0 0 0 1.25-1.25.625.625 0 1 1 1.25 0c.001.69.56 1.249 1.25 1.25a.625.625 0 1 1 0 1.25c-.69.001-1.249.56-1.25 1.25A.625.625 0 0 1 12.5 5Z" />
                    </svg>
                    <span class="sr-only">Switch to light / dark version</span>
                  </label>
                </div>
              </div>

              <div class="text-center pb-12 border-b border-gray-100 dark:border-gray-800">
                <div class="mb-5">
                  <div class="inline-flex items-center rounded-full px-3 py-1 text-[13px] font-medium bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 mb-5">
                    AI engineering studio
                  </div>
                  <h1 class="font-inter-tight font-bold text-gray-900 dark:text-gray-100 text-4xl md:text-5xl leading-tight mb-4">
                    Pattern<br class="sm:hidden"> Intelligence
                  </h1>
                  <p class="text-base md:text-lg text-gray-600 dark:text-gray-400 max-w-[520px] mx-auto mb-6">
                    Computer vision, medical imaging AI, and practical machine learning systems for real-world products.
                  </p>
                  <p class="text-sm text-gray-500 dark:text-gray-400 max-w-[440px] mx-auto mb-8">
                    Founded by Kaggle Grandmaster Yuji Ariyasu.
                  </p>
                </div>

                <div class="flex flex-wrap justify-center gap-3 mb-10">
                  <a class="btn-sm text-gray-200 dark:text-gray-800 bg-linear-to-r from-gray-800 to-gray-700 dark:from-gray-300 dark:to-gray-100 dark:hover:bg-gray-100 shadow-sm relative before:absolute before:inset-0 before:rounded-[inherit] before:bg-linear-[45deg,transparent_25%,var(--color-white)_50%,transparent_75%,transparent_100%] before:opacity-20 dark:before:opacity-100 before:bg-[length:250%_250%,100%_100%] before:bg-[position:200%_0,0_0] before:bg-no-repeat before:[transition:background-position_0s_ease] hover:before:bg-[position:-100%_0,0_0] hover:before:duration-1500" href="mailto:hello@patternint.com">Contact</a>
                  <a class="btn-sm bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-700 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-700" href="https://www.kaggle.com/yujiariyasu" target="_blank" rel="noreferrer">Kaggle</a>
                </div>

                <div class="group flex justify-center gap-4">
                  <img class="rounded-xl even:rotate-2 odd:-rotate-2 group-hover:even:rotate-0 group-hover:odd:rotate-0 transition duration-300 ease-[cubic-bezier(.5,.85,.25,1.8)] shadow-lg" src="./images/header-image-01.jpg" width="245" height="160" alt="AI research visual" />
                  <img class="rounded-xl even:rotate-2 odd:-rotate-2 group-hover:even:rotate-0 group-hover:odd:rotate-0 transition duration-300 ease-[cubic-bezier(.5,.85,.25,1.8)] shadow-lg" src="./images/header-image-02.jpg" width="245" height="160" alt="Engineering workspace visual" />
                  <img class="rounded-xl even:rotate-2 odd:-rotate-2 group-hover:even:rotate-0 group-hover:odd:rotate-0 transition duration-300 ease-[cubic-bezier(.5,.85,.25,1.8)] shadow-lg" src="./images/header-image-03.jpg" width="245" height="160" alt="Machine learning visual" />
                </div>
              </div>
            </header>

            <main class="grow py-12 space-y-12">
              <section>
                <h2 class="font-inter-tight text-lg font-semibold text-gray-800 dark:text-gray-100 mb-6">About</h2>
                <div class="p-6 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                  <p class="text-sm md:text-[15px] leading-7 text-gray-600 dark:text-gray-400">
                    Pattern Intelligence is a small AI engineering studio focused on building reliable machine learning systems with a strong emphasis on computer vision. The firm combines competition-grade modeling expertise with practical product development experience in healthcare and applied AI.
                  </p>
                </div>
              </section>

              <section>
                <h2 class="font-inter-tight text-lg font-semibold text-gray-800 dark:text-gray-100 mb-6">Services</h2>
                <div class="grid min-[580px]:grid-cols-2 gap-4">
                  <article class="p-5 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                    <h3 class="font-semibold text-gray-800 dark:text-gray-100 mb-2">Computer Vision</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Model design, training, evaluation, and deployment for image and video understanding.</p>
                  </article>
                  <article class="p-5 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                    <h3 class="font-semibold text-gray-800 dark:text-gray-100 mb-2">Medical Imaging AI</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Applied research and product-oriented development for clinical and healthcare imaging workflows.</p>
                  </article>
                  <article class="p-5 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                    <h3 class="font-semibold text-gray-800 dark:text-gray-100 mb-2">ML Systems</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Training pipelines, inference optimization, experiment management, and production integration.</p>
                  </article>
                  <article class="p-5 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                    <h3 class="font-semibold text-gray-800 dark:text-gray-100 mb-2">Technical Advisory</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Model strategy, data strategy, and feasibility reviews for AI-driven products and internal teams.</p>
                  </article>
                </div>
              </section>

              <section>
                <h2 class="font-inter-tight text-lg font-semibold text-gray-800 dark:text-gray-100 mb-6">Credentials</h2>
                <div class="space-y-4">
                  <article class="p-5 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                    <div class="text-[13px] italic text-gray-500/70 mb-1">Founder profile</div>
                    <h3 class="font-semibold text-gray-800 dark:text-gray-100 mb-2">Yuji Ariyasu</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Kaggle Grandmaster and medical imaging AI engineer based in Japan.</p>
                  </article>
                  <article class="p-5 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                    <div class="text-[13px] italic text-gray-500/70 mb-1">Selected achievements</div>
                    <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400 list-disc pl-5">
                      <li>Kaggle Grandmaster</li>
                      <li>5× RSNA Kaggle Prize Winner</li>
                      <li>Kaggle Days World Championship Winner</li>
                    </ul>
                  </article>
                </div>
              </section>

              <section>
                <h2 class="font-inter-tight text-lg font-semibold text-gray-800 dark:text-gray-100 mb-6">Focus Areas</h2>
                <div class="flex flex-wrap gap-2">
                  <span class="px-3 py-1.5 rounded-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">Computer Vision</span>
                  <span class="px-3 py-1.5 rounded-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">Medical Imaging</span>
                  <span class="px-3 py-1.5 rounded-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">PyTorch</span>
                  <span class="px-3 py-1.5 rounded-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">LLM Systems</span>
                  <span class="px-3 py-1.5 rounded-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">AWS</span>
                  <span class="px-3 py-1.5 rounded-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">Model Optimization</span>
                </div>
              </section>

              <section>
                <h2 class="font-inter-tight text-lg font-semibold text-gray-800 dark:text-gray-100 mb-6">Contact</h2>
                <div class="p-6 rounded-xl bg-linear-to-tr from-gray-100 to-gray-50 dark:from-gray-800 dark:to-gray-800/[0.65]">
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
                    For collaboration, consulting, or project inquiries, please get in touch.
                  </p>
                  <div class="space-y-2 text-sm">
                    <p><span class="text-gray-500 dark:text-gray-400">Email:</span> <a class="text-gray-800 dark:text-gray-100 hover:underline" href="mailto:hello@patternint.com">hello@patternint.com</a></p>
                    <p><span class="text-gray-500 dark:text-gray-400">LinkedIn:</span> <a class="text-gray-800 dark:text-gray-100 hover:underline" href="https://www.linkedin.com/in/yujiariyasu/" target="_blank" rel="noreferrer">linkedin.com/in/yujiariyasu</a></p>
                    <p><span class="text-gray-500 dark:text-gray-400">Kaggle:</span> <a class="text-gray-800 dark:text-gray-100 hover:underline" href="https://www.kaggle.com/yujiariyasu" target="_blank" rel="noreferrer">kaggle.com/yujiariyasu</a></p>
                  </div>
                </div>
              </section>
            </main>

            <footer class="space-y-6 text-center pb-16 pt-4 border-t border-gray-100 dark:border-gray-800">
              <ul class="inline-flex gap-4">
                <li>
                  <a class="w-8 h-8 rounded-full flex items-center justify-center bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600/[0.65] shadow-xs text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-100 transition-colors" href="https://www.kaggle.com/yujiariyasu" aria-label="Kaggle" target="_blank" rel="noreferrer">
                    <svg class="fill-current" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32"><path d="M21.469 26.766h4.094l-7.062-10.687 6.813-10.844h-4.031l-7.469 12.125V5.234h-3.531v21.531h3.531v-7.937l1.969-2.969z"/></svg>
                  </a>
                </li>
                <li>
                  <a class="w-8 h-8 rounded-full flex items-center justify-center bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600/[0.65] shadow-xs text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-100 transition-colors" href="https://github.com/" aria-label="GitHub" target="_blank" rel="noreferrer">
                    <svg class="fill-current" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                      <path d="M7.95 0C3.578 0 0 3.578 0 7.95c0 3.479 2.286 6.46 5.466 7.553.397.1.497-.199.497-.397v-1.392c-2.187.497-2.683-.994-2.683-.994-.398-.894-.895-1.192-.895-1.192-.696-.497.1-.497.1-.497.795.1 1.192.795 1.192.795.696 1.292 1.888.894 2.286.696.1-.497.298-.895.497-1.093-1.79-.2-3.578-.895-3.578-3.976 0-.894.298-1.59.795-2.087-.1-.198-.397-.993.1-2.086 0 0 .695-.2 2.186.795a6.408 6.408 0 0 1 1.987-.299c.696 0 1.392.1 1.988.299 1.49-.994 2.186-.796 2.186-.796.398 1.094.199 1.889.1 2.087.496.597.795 1.292.795 2.087 0 3.081-1.889 3.677-3.677 3.876.298.398.596.895.596 1.59v2.187c0 .198.1.496.596.397C13.714 14.41 16 11.43 16 7.95 15.9 3.578 12.323 0 7.95 0Z" />
                    </svg>
                  </a>
                </li>
                <li>
                  <a class="w-8 h-8 rounded-full flex items-center justify-center bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600/[0.65] shadow-xs text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-100 transition-colors" href="https://www.linkedin.com/in/yujiariyasu/" aria-label="LinkedIn" target="_blank" rel="noreferrer">
                    <svg class="fill-current" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"><path d="M6.94 8.5H3.56V20h3.38zM5.25 3A1.97 1.97 0 1 0 5.3 6.94 1.97 1.97 0 0 0 5.25 3zM20 13.08C20 9.7 18.2 8.14 15.8 8.14c-1.94 0-2.8 1.06-3.28 1.8V8.5H9.14c.04.96 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.69.13-.94.27-.68.88-1.38 1.9-1.38 1.34 0 1.88 1.02 1.88 2.52V20H20z"/></svg>
                  </a>
                </li>
              </ul>
              <p class="text-sm text-gray-400 dark:text-gray-600">© Pattern Intelligence. All rights reserved.</p>
            </footer>

          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="./js/vendors/alpinejs.min.js" defer></script>
  <script src="./js/main.js"></script>
</body>
</html>
